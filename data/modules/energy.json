  "topics": [
    {
      "topic_id": "kinetic_energy",
      "title": "Kinetic Energy",
      "order": 1,
      "explanation": {
        "simple": "Kinetic energy is the energy an object has because it is moving. The faster something moves or the heavier it is, the more kinetic energy it has. A rolling ball, a flying bird, and a moving car all have kinetic energy.",
        "advanced": "Kinetic energy (KE) is a scalar quantity defined as the work needed to accelerate a body of mass m from rest to velocity v. It is frame-dependent and always non-negative. For relativistic speeds, the classical formula is replaced by the Lorentz factor expression. In the work-energy theorem, the net work done on a particle equals its change in kinetic energy: W_net = ΔKE."
      },
      "formulas": [
        {
          "name": "Kinetic Energy",
          "latex": "KE = \\frac{1}{2}mv^2",
          "variables": {
            "KE": {"description": "Kinetic energy", "unit": "J (Joules)"},
            "m": {"description": "Mass of the object", "unit": "kg"},
            "v": {"description": "Velocity of the object", "unit": "m/s"}
          }
        },
        {
          "name": "Work-Energy Theorem",
          "latex": "W_{net} = \\Delta KE = \\frac{1}{2}mv_f^2 - \\frac{1}{2}mv_i^2",
          "variables": {
            "W_net": {"description": "Net work done", "unit": "J"},
            "v_f": {"description": "Final velocity", "unit": "m/s"},
            "v_i": {"description": "Initial velocity", "unit": "m/s"}
          }
        },
        {
          "name": "KE in terms of momentum",
          "latex": "KE = \\frac{p^2}{2m}",
          "variables": {
            "p": {"description": "Linear momentum (p = mv)", "unit": "kg·m/s"}
          }
        }
      ],
