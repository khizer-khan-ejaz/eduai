        {
          "title": "Car in Motion",
          "description": "A 1000 kg car traveling at 20 m/s has KE = ½ × 1000 × 20² = 200,000 J. This is why speed matters more than mass in crashes — energy scales with v².",
          "calculation": "KE = 0.5 × 1000 × 400 = 200,000 J"
        },
