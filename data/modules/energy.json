      "quiz": {
        "mcq": [
          {
            "question": "If the velocity of an object doubles, its kinetic energy:",
            "options": ["Doubles", "Triples", "Quadruples", "Stays the same"],
            "correct": 2,
            "explanation": "KE = ½mv². If v → 2v, then KE = ½m(2v)² = ½m(4v²) = 4 × (½mv²). So KE quadruples.",
            "difficulty": "medium"
          },
          {
            "question": "A 2 kg ball moving at 3 m/s has kinetic energy of:",
            "options": ["6 J", "9 J", "12 J", "18 J"],
            "correct": 1,
            "explanation": "KE = ½ × 2 × 3² = ½ × 2 × 9 = 9 J.",
            "difficulty": "easy"
          },
          {
            "question": "Which has more kinetic energy: a 10 kg object at 2 m/s or a 2 kg object at 10 m/s?",
            "options": ["10 kg object", "2 kg object", "They are equal", "Cannot determine"],
            "correct": 1,
            "explanation": "10 kg at 2 m/s: KE = ½ × 10 × 4 = 20 J. 2 kg at 10 m/s: KE = ½ × 2 × 100 = 100 J. The lighter, faster object has more KE.",
            "difficulty": "medium"
          },
          {
            "question": "Kinetic energy is a _____ quantity.",
            "options": ["Vector", "Scalar", "Tensor", "Imaginary"],
            "correct": 1,
            "explanation": "Kinetic energy has only magnitude, no direction. It is always a non-negative scalar quantity.",
            "difficulty": "easy"
          }
        ],
        "short_answer": [
          {
            "question": "A truck of mass 5000 kg accelerates from rest to 15 m/s. Calculate its kinetic energy.",
            "answer": "KE = ½ × 5000 × 15² = ½ × 5000 × 225 = 562,500 J = 562.5 kJ",
            "hint": "Use KE = ½mv² with m = 5000 kg and v = 15 m/s."
          },
          {
            "question": "Explain why a bullet (small mass, high velocity) can be more dangerous than a slow-moving heavy object.",
            "answer": "Kinetic energy depends on the square of velocity (KE = ½mv²). Since velocity is squared, a small increase in speed contributes much more to energy than a proportional increase in mass. A 10 g bullet at 300 m/s has KE = 450 J, while a 10 kg rock at 1 m/s has KE = 5 J.",
            "hint": "Think about how KE scales with velocity vs. mass."
          }
        ]
      }
