    {
      "topic_id": "potential_energy",
      "title": "Potential Energy",
      "order": 2,
      "explanation": {
        "simple": "Potential energy is stored energy — energy an object has because of its position or shape. A book on a shelf, a stretched rubber band, or water at the top of a waterfall all have potential energy waiting to be released.",
        "advanced": "Potential energy is the energy stored in a system due to the relative positions of its components or its configuration. Gravitational PE depends on height in a gravitational field (U = mgh near Earth's surface, U = -GMm/r in general). Elastic PE follows Hooke's law (U = ½kx²). Electric PE arises from charge configurations in electric fields. The negative gradient of potential energy gives the conservative force: F = -∇U."
      },
      "formulas": [
        {
          "name": "Gravitational Potential Energy (near surface)",
          "latex": "PE = mgh",
          "variables": {
            "PE": {"description": "Gravitational potential energy", "unit": "J"},
            "m": {"description": "Mass", "unit": "kg"},
            "g": {"description": "Acceleration due to gravity (≈ 9.8 m/s²)", "unit": "m/s²"},
            "h": {"description": "Height above reference point", "unit": "m"}
          }
        },
        {
          "name": "Gravitational PE (general)",
          "latex": "U = -\\frac{GMm}{r}",
          "variables": {
            "G": {"description": "Gravitational constant (6.674 × 10⁻¹¹)", "unit": "N·m²/kg²"},
            "M": {"description": "Mass of the larger body", "unit": "kg"},
            "r": {"description": "Distance between centers of mass", "unit": "m"}
          }
        },
        {
          "name": "Elastic Potential Energy",
          "latex": "PE_{elastic} = \\frac{1}{2}kx^2",
          "variables": {
            "k": {"description": "Spring constant", "unit": "N/m"},
            "x": {"description": "Displacement from equilibrium", "unit": "m"}
          }
        }
      ],
