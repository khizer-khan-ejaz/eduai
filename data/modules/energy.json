    {
      "topic_id": "conservation_of_energy",
      "title": "Conservation of Energy",
      "order": 3,
      "explanation": {
        "simple": "Energy cannot be created or destroyed — it can only change form. When a ball falls, its potential energy transforms into kinetic energy. The total energy in a closed system always stays the same. This is one of the most important laws in all of physics!",
        "advanced": "The Law of Conservation of Energy states that the total energy of an isolated system remains constant over time. Energy can transform between forms (kinetic, potential, thermal, chemical, nuclear, electromagnetic), but the total is invariant. Mathematically: E_total = KE + PE + E_thermal + E_other = constant. This principle arises from Noether's theorem as a consequence of time translation symmetry of the laws of physics. In thermodynamics, this corresponds to the First Law: ΔU = Q - W."
      },
      "formulas": [
        {
          "name": "Conservation of Mechanical Energy",
          "latex": "KE_i + PE_i = KE_f + PE_f",
          "variables": {
            "KE_i": {"description": "Initial kinetic energy", "unit": "J"},
            "PE_i": {"description": "Initial potential energy", "unit": "J"},
            "KE_f": {"description": "Final kinetic energy", "unit": "J"},
            "PE_f": {"description": "Final potential energy", "unit": "J"}
          }
        },
        {
          "name": "Total Energy (with dissipation)",
          "latex": "E_{total} = KE + PE + E_{thermal} + E_{other}",
          "variables": {
            "E_thermal": {"description": "Thermal energy (heat from friction, etc.)", "unit": "J"}
          }
        },
        {
          "name": "First Law of Thermodynamics",
          "latex": "\\Delta U = Q - W",
          "variables": {
            "ΔU": {"description": "Change in internal energy", "unit": "J"},
            "Q": {"description": "Heat added to the system", "unit": "J"},
            "W": {"description": "Work done by the system", "unit": "J"}
          }
        }
      ],
