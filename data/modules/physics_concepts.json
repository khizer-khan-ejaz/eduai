  "topics": [
    {
      "topic_id": "kinematics",
      "title": "Motion & Kinematics",
      "order": 1,
      "explanation": {
        "simple": "Kinematics is the study of how things move without worrying about what causes the motion. We describe motion using four quantities: displacement (how far and in what direction), velocity (how fast and in what direction), acceleration (how velocity changes), and time. The three equations of motion connect these quantities.",
        "advanced": "Kinematics describes motion using displacement (s), velocity (v = ds/dt), and acceleration (a = dv/dt = d²s/dt²) as functions of time. For uniform acceleration, three kinematic equations relate these quantities. In vector form, each component (x, y, z) can be treated independently — this is crucial for projectile motion, where horizontal motion is uniform and vertical motion is uniformly accelerated. The kinematic equations are derivable from integration of a = constant."
      },
      "formulas": [
        {
          "name": "First Equation of Motion",
          "latex": "v = u + at",
          "variables": {
            "v": {"description": "Final velocity", "unit": "m/s"},
            "u": {"description": "Initial velocity", "unit": "m/s"},
            "a": {"description": "Acceleration", "unit": "m/s²"},
            "t": {"description": "Time", "unit": "s"}
          }
        },
        {
          "name": "Second Equation of Motion",
          "latex": "s = ut + \\frac{1}{2}at^2",
          "variables": {
            "s": {"description": "Displacement", "unit": "m"}
          }
        },
        {
          "name": "Third Equation of Motion",
          "latex": "v^2 = u^2 + 2as",
          "variables": {}
        },
        {
          "name": "Average Velocity",
          "latex": "v_{avg} = \\frac{s}{t} = \\frac{u + v}{2}",
          "variables": {}
        },
        {
          "name": "Projectile — Maximum Height",
          "latex": "H = \\frac{u^2 \\sin^2\\theta}{2g}",
          "variables": {
            "θ": {"description": "Launch angle", "unit": "°"},
            "g": {"description": "Gravitational acceleration", "unit": "m/s²"}
          }
        },
        {
          "name": "Projectile — Range",
          "latex": "R = \\frac{u^2 \\sin 2\\theta}{g}",
          "variables": {}
        },
        {
          "name": "Projectile — Time of Flight",
          "latex": "T = \\frac{2u \\sin\\theta}{g}",
          "variables": {}
        }
      ],
