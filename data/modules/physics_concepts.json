      "real_world_examples": [
        {
          "title": "Basketball Shot",
          "description": "A basketball thrown at 8 m/s at 52° has a range of about 6.4 m and reaches a max height of 2.5 m. Players intuitively optimize launch angle for the basket distance.",
          "calculation": "R = 64 × sin(104°)/9.8 ≈ 6.4 m; H = 64 × sin²(52°)/(2×9.8) ≈ 2.5 m"
        },
        {
          "title": "Sprinter's Race",
          "description": "Usain Bolt accelerated from 0 to ~12.2 m/s in the first 4 seconds of his 100m record. Average acceleration ≈ 3.05 m/s². Distance in that phase: s = ½ × 3.05 × 16 ≈ 24.4 m.",
          "calculation": "a = Δv/Δt = 12.2/4 = 3.05 m/s²; s = ½at² = 0.5 × 3.05 × 16 ≈ 24.4 m"
        }
      ],
      "quiz": {
        "mcq": [
          {
            "question": "A car accelerates from rest at 2 m/s². Its velocity after 5 seconds is:",
            "options": ["5 m/s", "10 m/s", "20 m/s", "25 m/s"],
            "correct": 1,
            "explanation": "v = u + at = 0 + 2 × 5 = 10 m/s.",
            "difficulty": "easy"
          },
          {
            "question": "For maximum range of a projectile (no air resistance), the launch angle should be:",
            "options": ["30°", "45°", "60°", "90°"],
            "correct": 1,
            "explanation": "R = u²sin2θ/g is maximum when sin2θ = 1, i.e., 2θ = 90°, so θ = 45°.",
            "difficulty": "medium"
          },
          {
            "question": "In projectile motion, horizontal velocity remains constant because:",
            "options": ["Gravity is zero", "There is no horizontal force", "Mass is constant", "Time is constant"],
            "correct": 1,
            "explanation": "Gravity acts only vertically. With no horizontal force (ignoring air resistance), horizontal velocity stays constant (Newton's 1st law).",
            "difficulty": "medium"
          },
          {
            "question": "Distance covered in the nth second of uniform acceleration from rest is:",
            "options": ["½a(2n-1)", "½an²", "an", "½a(n²-1)"],
            "correct": 0,
            "explanation": "Sₙ = u + a(n - ½) = 0 + a(n - 0.5) = a(2n-1)/2. This comes from s(n) - s(n-1).",
            "difficulty": "hard"
          }
        ],
        "short_answer": [
          {
            "question": "A stone is thrown upward with velocity 20 m/s. Find (a) max height, (b) time to reach the top, (c) total time in air. (g = 10 m/s²)",
            "answer": "(a) H = u²/(2g) = 400/20 = 20 m. (b) t_up = u/g = 20/10 = 2 s. (c) T_total = 2u/g = 40/10 = 4 s.",
            "hint": "At max height, v = 0. Use v = u - gt for time and v² = u² - 2gs for height."
          }
        ]
      }
