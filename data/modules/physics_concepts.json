      "topic_id": "fields",
      "title": "Fields: Gravitational & Electric",
      "order": 4,
      "explanation": {
        "simple": "A field is an invisible region of influence around an object. Earth has a gravitational field that pulls things toward it. A charged object has an electric field that affects other charges. Fields allow forces to act at a distance without physical contact. Field lines show the direction and strength of the field.",
        "advanced": "A field is a physical quantity that has a value at every point in space. Scalar fields (temperature, potential) assign a number; vector fields (gravitational, electric, magnetic) assign a vector. The gravitational field g = F/m = -GM/r² r̂ points toward the mass. The electric field E = F/q = kQ/r² r̂ points away from positive charges. Field lines are tangent to the field vector at every point. Field strength is proportional to line density. The potential is the negative line integral of the field: V = -∫E·dr. Both fields obey the inverse-square law."
      },
      "formulas": [
        {
          "name": "Gravitational Field Strength",
          "latex": "\\vec{g} = \\frac{\\vec{F}}{m} = -\\frac{GM}{r^2}\\hat{r}",
          "variables": {
            "g": {"description": "Gravitational field strength", "unit": "N/kg or m/s²"},
            "G": {"description": "Gravitational constant", "unit": "N·m²/kg²"},
            "M": {"description": "Mass creating the field", "unit": "kg"},
            "r": {"description": "Distance from center of mass", "unit": "m"}
          }
        },
        {
          "name": "Gravitational Potential",
          "latex": "V_g = -\\frac{GM}{r}",
          "variables": {
            "V_g": {"description": "Gravitational potential", "unit": "J/kg"}
          }
        },
        {
          "name": "Electric Field (point charge)",
          "latex": "\\vec{E} = \\frac{kQ}{r^2}\\hat{r} = \\frac{1}{4\\pi\\epsilon_0}\\frac{Q}{r^2}\\hat{r}",
          "variables": {
            "E": {"description": "Electric field strength", "unit": "N/C or V/m"},
            "k": {"description": "Coulomb's constant (8.99 × 10⁹ N·m²/C²)", "unit": ""},
            "Q": {"description": "Source charge", "unit": "C (Coulombs)"},
            "ε₀": {"description": "Permittivity of free space (8.854 × 10⁻¹² F/m)", "unit": "F/m"}
          }
        },
        {
          "name": "Coulomb's Law",
          "latex": "F = \\frac{kq_1 q_2}{r^2}",
          "variables": {
            "q₁, q₂": {"description": "Point charges", "unit": "C"}
          }
        },
        {
          "name": "Electric Potential",
          "latex": "V = \\frac{kQ}{r}",
          "variables": {
            "V": {"description": "Electric potential", "unit": "V (Volts)"}
          }
        },
        {
          "name": "Relationship between E and V",
          "latex": "E = -\\frac{dV}{dr}",
          "variables": {}
        }
